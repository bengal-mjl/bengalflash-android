<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".activity.TakePhotoActivity">

    <!-- 相机预览 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 证件框遮罩 -->
    <com.example.cashcredit.ui.IdCardOverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 拍照结果显示 -->
    <ImageView
        android:id="@+id/ivTakeResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- 加载进度 -->
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- 拍照按钮区域 -->
    <LinearLayout
        android:id="@+id/llTakeCamera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- 拍照按钮 -->
        <ImageView
            android:id="@+id/btnTakePhoto"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_camera_button" />

    </LinearLayout>

    <!-- 确认/重拍按钮区域 -->
    <LinearLayout
        android:id="@+id/cameraOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="32dp"
        android:visibility="gone">

        <!-- 重拍按钮（叉图标） -->
        <ImageView
            android:id="@+id/btnRetake"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="60dp"
            android:background="@drawable/bg_circle_red"
            android:padding="20dp"
            android:src="@drawable/ic_retake" />

        <!-- 确认按钮（勾图标） -->
        <ImageView
            android:id="@+id/btnConfirm"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_circle_green"
            android:padding="20dp"
            android:src="@drawable/ic_confirm" />

    </LinearLayout>

</RelativeLayout>